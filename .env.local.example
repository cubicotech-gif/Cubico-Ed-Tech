# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Setup instructions ─────────────────────────────────────────────────────────
# 1. Copy this file to .env.local
#    cp .env.local.example .env.local
#
# 2. Fill in your Supabase URL and anon key above.
#
# 3. In your Supabase project, run the following SQL to create tables:
#
#    -- Portfolio projects table
#    CREATE TABLE portfolio_projects (
#      id          UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#      title       TEXT NOT NULL,
#      category    TEXT NOT NULL CHECK (category IN ('LMS', 'Animation', 'Apps', 'Content')),
#      description TEXT NOT NULL,
#      tags        TEXT[] DEFAULT '{}',
#      image_url   TEXT,
#      created_at  TIMESTAMPTZ DEFAULT NOW()
#    );
#
#    -- Enable RLS and allow public read
#    ALTER TABLE portfolio_projects ENABLE ROW LEVEL SECURITY;
#    CREATE POLICY "Public read" ON portfolio_projects FOR SELECT USING (true);
#
#    -- Contact submissions table
#    CREATE TABLE contact_submissions (
#      id          UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#      name        TEXT NOT NULL,
#      email       TEXT NOT NULL,
#      institution TEXT DEFAULT '',
#      service     TEXT DEFAULT '',
#      message     TEXT NOT NULL,
#      created_at  TIMESTAMPTZ DEFAULT NOW()
#    );
#
#    -- Enable RLS and allow public insert
#    ALTER TABLE contact_submissions ENABLE ROW LEVEL SECURITY;
#    CREATE POLICY "Public insert" ON contact_submissions FOR INSERT WITH CHECK (true);
#
# 4. Create a Storage bucket called "portfolio" (public) for project images.
#    Supabase Dashboard → Storage → New bucket → Name: portfolio → Public: ON
